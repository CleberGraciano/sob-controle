COMPOSE_PROJECT_NAME=sob-controle

POSTGRES_DB=finance_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=4200

